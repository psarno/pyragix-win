<Application
    x:Class="PyRagix.Win.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:PyRagix.Win.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <views:NullToBoolConverter x:Key="NullToBoolConverter" />
            <views:InvertBoolConverter x:Key="InvertBoolConverter" />
            <views:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <views:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibilityConverter" />
            <views:MarkdownNormalizeConverter x:Key="MarkdownNormalizeConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
