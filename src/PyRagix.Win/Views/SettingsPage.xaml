<Page
    x:Class="PyRagix.Win.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctk="using:CommunityToolkit.WinUI.Controls"
    xmlns:local="using:PyRagix.Win.Views"
    Loaded="SettingsPage_Loaded">

    <Page.Resources>
        <local:IntToDoubleConverter x:Key="IntToDoubleConverter" />
        <local:BoolToErrorBrushConverter x:Key="BoolToErrorBrushConverter" />
    </Page.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- Scrollable settings body -->
        <ScrollViewer x:Name="SettingsScrollViewer" Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="SettingsContent" Spacing="4" Margin="24,20,24,12" Background="Transparent">

                <TextBlock
                    Text="Settings"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Margin="0,0,0,16" />

                <!-- ── Chat ──────────────────────────────────────────────── -->
                <ctk:SettingsExpander
                    Header="Chat"
                    Description="Chat display preferences">
                    <ctk:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE8BD;" />
                    </ctk:SettingsExpander.HeaderIcon>
                    <ctk:SettingsExpander.Items>
                        <ctk:SettingsCard
                            Header="Show Thinking Blocks"
                            Description="Display the model's chain-of-thought reasoning in a collapsible section (applies to new messages)">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.ShowThinkingBlocks, Mode=TwoWay}" />
                        </ctk:SettingsCard>
                    </ctk:SettingsExpander.Items>
                </ctk:SettingsExpander>

                <!-- ── Features ───────────────────────────────────────────── -->
                <!-- NOTE: Features is intentionally first. SettingsExpander uses an internal
                     ItemsRepeater that only realizes items visible in the outer ScrollViewer's
                     effective viewport at the moment the expander first opens. With LLM (7 items,
                     ~433 px) above Features, the Features ItemsRepeater would connect to the
                     ScrollViewer with a near-zero effective viewport and never realize its items
                     → hit-test invisible. Placing Features first ensures its items are fully
                     inside the viewport when the ItemsRepeater initializes. -->
                <ctk:SettingsExpander
                    x:Name="FeaturesExpander"
                    Header="Features"
                    Description="Pipeline feature toggles">
                    <ctk:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE713;" />
                    </ctk:SettingsExpander.HeaderIcon>
                    <ctk:SettingsExpander.Items>

                        <ctk:SettingsCard Header="Semantic Chunking" Description="Split documents at sentence boundaries instead of fixed-size windows">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.EnableSemanticChunking, Mode=TwoWay}" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="Query Expansion" Description="Generate alternative query phrasings to improve recall">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.EnableQueryExpansion, Mode=TwoWay}" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="Hybrid Search" Description="Combine FAISS vector search with Lucene BM25 keyword search">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.EnableHybridSearch, Mode=TwoWay}" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="Reranking" Description="Re-score candidates with a cross-encoder ONNX model">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.EnableReranking, Mode=TwoWay}" />
                        </ctk:SettingsCard>

                    </ctk:SettingsExpander.Items>
                </ctk:SettingsExpander>

                <!-- ── LLM ─────────────────────────────────────────────── -->
                <ctk:SettingsExpander
                    x:Name="LlmExpander"
                    Header="LLM"
                    Description="Inference server and generation parameters">
                    <ctk:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE8D4;" />
                    </ctk:SettingsExpander.HeaderIcon>
                    <ctk:SettingsExpander.Items>

                        <ctk:SettingsCard Header="Endpoint" Description="Base URL of the OpenAI-compatible server">
                            <TextBox
                                Text="{x:Bind ViewModel.LlmEndpoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Width="280" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="Model" Description="Model identifier sent to the server">
                            <TextBox
                                Text="{x:Bind ViewModel.LlmModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Width="200" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="Temperature" Description="Sampling temperature (0 = deterministic)">
                            <NumberBox
                                Value="{x:Bind ViewModel.Temperature, Mode=TwoWay}"
                                Minimum="0" Maximum="2" SmallChange="0.05" LargeChange="0.1"
                                SpinButtonPlacementMode="Compact"
                                Width="120" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="Top-P" Description="Nucleus sampling probability mass">
                            <NumberBox
                                Value="{x:Bind ViewModel.TopP, Mode=TwoWay}"
                                Minimum="0" Maximum="1" SmallChange="0.05"
                                SpinButtonPlacementMode="Compact"
                                Width="120" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="Max Tokens" Description="Maximum tokens per response">
                            <NumberBox
                                Value="{x:Bind ViewModel.MaxTokens, Mode=TwoWay, Converter={StaticResource IntToDoubleConverter}}"
                                Minimum="64" Maximum="8192" SmallChange="64" LargeChange="256"
                                SpinButtonPlacementMode="Compact"
                                Width="120" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="Request Timeout" Description="HTTP timeout in seconds">
                            <NumberBox
                                Value="{x:Bind ViewModel.RequestTimeout, Mode=TwoWay, Converter={StaticResource IntToDoubleConverter}}"
                                Minimum="10" Maximum="600" SmallChange="10"
                                SpinButtonPlacementMode="Compact"
                                Width="120" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="Test Connection">
                            <ctk:SettingsCard.Description>
                                <StackPanel>
                                    <TextBlock Text="Ping the inference server endpoint" />
                                    <TextBlock
                                        Text="{x:Bind ViewModel.ConnectionStatus, Mode=OneWay}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Foreground="{x:Bind ViewModel.IsConnectionError, Mode=OneWay, Converter={StaticResource BoolToErrorBrushConverter}}"
                                        TextWrapping="Wrap"
                                        Visibility="{x:Bind ViewModel.HasConnectionStatus, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Margin="0,2,0,0" />
                                </StackPanel>
                            </ctk:SettingsCard.Description>
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <ProgressRing
                                    IsActive="{x:Bind ViewModel.IsConnectionTesting, Mode=OneWay}"
                                    Width="20" Height="20" />
                                <Button
                                    Content="Test"
                                    Command="{x:Bind ViewModel.TestConnectionCommand}" />
                            </StackPanel>
                        </ctk:SettingsCard>

                    </ctk:SettingsExpander.Items>
                </ctk:SettingsExpander>

                <!-- ── Performance ────────────────────────────────────────── -->
                <ctk:SettingsExpander
                    Header="Performance"
                    Description="Retrieval and chunking tuning">
                    <ctk:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </ctk:SettingsExpander.HeaderIcon>
                    <ctk:SettingsExpander.Items>

                        <ctk:SettingsCard Header="Default Top-K" Description="Chunks sent to the LLM as context">
                            <NumberBox
                                Value="{x:Bind ViewModel.DefaultTopK, Mode=TwoWay, Converter={StaticResource IntToDoubleConverter}}"
                                Minimum="1" Maximum="50" SmallChange="1"
                                SpinButtonPlacementMode="Compact" Width="100" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="Chunk Size" Description="Target character count per chunk">
                            <NumberBox
                                Value="{x:Bind ViewModel.ChunkSize, Mode=TwoWay, Converter={StaticResource IntToDoubleConverter}}"
                                Minimum="128" Maximum="8192" SmallChange="128" LargeChange="512"
                                SpinButtonPlacementMode="Compact" Width="120" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="Chunk Overlap" Description="Characters carried forward from the previous chunk">
                            <NumberBox
                                Value="{x:Bind ViewModel.ChunkOverlap, Mode=TwoWay, Converter={StaticResource IntToDoubleConverter}}"
                                Minimum="0" Maximum="2048" SmallChange="50"
                                SpinButtonPlacementMode="Compact" Width="120" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="Hybrid Alpha" Description="Vector search weight (1 − alpha goes to keyword search)">
                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <Slider
                                    Value="{x:Bind ViewModel.HybridAlpha, Mode=TwoWay}"
                                    Minimum="0" Maximum="1" StepFrequency="0.05"
                                    Width="180" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.HybridAlpha, Mode=OneWay}"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Width="36" />
                            </StackPanel>
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="Rerank Top-K" Description="Candidates passed to the reranker before trimming to Top-K">
                            <NumberBox
                                Value="{x:Bind ViewModel.RerankTopK, Mode=TwoWay, Converter={StaticResource IntToDoubleConverter}}"
                                Minimum="1" Maximum="100" SmallChange="5"
                                SpinButtonPlacementMode="Compact" Width="100" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="Query Expansion Count" Description="Extra query phrasings to generate">
                            <NumberBox
                                Value="{x:Bind ViewModel.QueryExpansionCount, Mode=TwoWay, Converter={StaticResource IntToDoubleConverter}}"
                                Minimum="1" Maximum="10" SmallChange="1"
                                SpinButtonPlacementMode="Compact" Width="100" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="Embedding Batch Size" Description="Texts processed per ONNX inference call">
                            <NumberBox
                                Value="{x:Bind ViewModel.EmbeddingBatchSize, Mode=TwoWay, Converter={StaticResource IntToDoubleConverter}}"
                                Minimum="1" Maximum="256" SmallChange="8"
                                SpinButtonPlacementMode="Compact" Width="100" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="Embedding Dimension" Description="Vector dimensionality (384 for MiniLM-L6-v2)">
                            <NumberBox
                                Value="{x:Bind ViewModel.EmbeddingDimension, Mode=TwoWay, Converter={StaticResource IntToDoubleConverter}}"
                                Minimum="64" Maximum="4096" SmallChange="64"
                                SpinButtonPlacementMode="Compact" Width="100" />
                        </ctk:SettingsCard>

                    </ctk:SettingsExpander.Items>
                </ctk:SettingsExpander>

                <!-- ── Paths ──────────────────────────────────────────────── -->
                <ctk:SettingsExpander
                    Header="Paths"
                    Description="Model files and index storage locations">
                    <ctk:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE8B7;" />
                    </ctk:SettingsExpander.HeaderIcon>
                    <ctk:SettingsExpander.Items>

                        <ctk:SettingsCard Header="Embedding Model" Description="ONNX model file for sentence embeddings">
                            <TextBox
                                Text="{x:Bind ViewModel.EmbeddingModelPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Width="340" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="Reranker Model" Description="ONNX cross-encoder model file">
                            <TextBox
                                Text="{x:Bind ViewModel.RerankerModelPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Width="340" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="Database" Description="SQLite file for chunk metadata">
                            <TextBox
                                Text="{x:Bind ViewModel.DatabasePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Width="240" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="FAISS Index" Description="Vector index binary">
                            <TextBox
                                Text="{x:Bind ViewModel.FaissIndexPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Width="240" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="Lucene Index" Description="BM25 keyword index directory">
                            <TextBox
                                Text="{x:Bind ViewModel.LuceneIndexPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Width="240" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="BM25 Index" Description="Reserved — not used in the current pipeline">
                            <TextBox
                                Text="{x:Bind ViewModel.BM25IndexPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Width="240"
                                IsEnabled="False"
                                Opacity="0.5" />
                        </ctk:SettingsCard>

                    </ctk:SettingsExpander.Items>
                </ctk:SettingsExpander>

                <!-- ── GPU ────────────────────────────────────────────────── -->
                <ctk:SettingsExpander
                    Header="GPU / ONNX"
                    Description="Execution provider for embedding and reranking inference">
                    <ctk:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE950;" />
                    </ctk:SettingsExpander.HeaderIcon>
                    <ctk:SettingsExpander.Items>

                        <ctk:SettingsCard Header="Execution Provider" Description="Auto tries CUDA first, falls back to CPU">
                            <ComboBox
                                ItemsSource="{x:Bind ViewModel.ExecutionProviders}"
                                SelectedItem="{x:Bind ViewModel.ExecutionProviderPreference, Mode=TwoWay}"
                                Width="140" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="GPU Device ID" Description="CUDA device index (0 = first GPU)">
                            <NumberBox
                                Value="{x:Bind ViewModel.GpuDeviceId, Mode=TwoWay, Converter={StaticResource IntToDoubleConverter}}"
                                Minimum="0" Maximum="7" SmallChange="1"
                                SpinButtonPlacementMode="Compact" Width="100" />
                        </ctk:SettingsCard>

                    </ctk:SettingsExpander.Items>
                </ctk:SettingsExpander>

                <!-- ── OCR ────────────────────────────────────────────────── -->
                <ctk:SettingsExpander
                    Header="OCR"
                    Description="Resolution settings for image-based document extraction">
                    <ctk:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE8D2;" />
                    </ctk:SettingsExpander.HeaderIcon>
                    <ctk:SettingsExpander.Items>

                        <ctk:SettingsCard Header="Base DPI" Description="Starting resolution for OCR attempts">
                            <NumberBox
                                Value="{x:Bind ViewModel.OcrBaseDpi, Mode=TwoWay, Converter={StaticResource IntToDoubleConverter}}"
                                Minimum="72" Maximum="600" SmallChange="50"
                                SpinButtonPlacementMode="Compact" Width="100" />
                        </ctk:SettingsCard>

                        <ctk:SettingsCard Header="Max DPI" Description="Final high-resolution retry DPI">
                            <NumberBox
                                Value="{x:Bind ViewModel.OcrMaxDpi, Mode=TwoWay, Converter={StaticResource IntToDoubleConverter}}"
                                Minimum="72" Maximum="1200" SmallChange="50"
                                SpinButtonPlacementMode="Compact" Width="100" />
                        </ctk:SettingsCard>

                    </ctk:SettingsExpander.Items>
                </ctk:SettingsExpander>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Action bar ──────────────────────────────────────────────────── -->
        <Grid Grid.Row="1" RowDefinitions="Auto,Auto" Margin="24,0,24,20">
            <Border
                Grid.Row="0"
                Height="1"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                Margin="0,0,0,12" />
            <StackPanel Grid.Row="1" Spacing="12">
                <InfoBar
                    IsOpen="{x:Bind ViewModel.HasSaveStatus, Mode=OneWay}"
                    Severity="{x:Bind ViewModel.SaveStatusSeverity, Mode=OneWay}"
                    Message="{x:Bind ViewModel.SaveStatus, Mode=OneWay}"
                    IsClosable="False" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button
                        Command="{x:Bind ViewModel.SaveCommand}"
                        Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74E;" FontSize="14" />
                            <TextBlock Text="Save" />
                        </StackPanel>
                    </Button>
                    <Button Command="{x:Bind ViewModel.ResetCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                            <TextBlock Text="Reset" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>

    </Grid>
</Page>
