<Page
    x:Class="PyRagix.Win.Views.DocumentsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:PyRagix.Win.Models"
    xmlns:local="using:PyRagix.Win.Views">

    <Page.Resources>
        <local:LogLevelToBrushConverter x:Key="LogLevelToBrushConverter" />
        <local:NonZeroToVisibilityConverter x:Key="NonZeroToVisibilityConverter" />
        <local:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter" />
        <local:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibilityConverter" />

        <DataTemplate x:Key="LogEntryTemplate" x:DataType="models:IngestionLogEntry">
            <Grid Padding="0,2">
                <TextBlock
                    Text="{x:Bind FormattedMessage}"
                    Foreground="{x:Bind Level, Converter={StaticResource LogLevelToBrushConverter}}"
                    FontFamily="Cascadia Code, Consolas, Courier New"
                    FontSize="12"
                    TextWrapping="Wrap" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid RowDefinitions="Auto,Auto,*" Margin="24,20,24,20">

        <!-- Top: folder picker + options + actions -->
        <StackPanel Grid.Row="0" Spacing="12">

            <!-- Folder picker row -->
            <TextBlock Text="Source Folder" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <Grid ColumnDefinitions="*,Auto">
                <TextBox
                    Grid.Column="0"
                    x:Name="FolderBox"
                    Text="{x:Bind ViewModel.SelectedFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="Select a folder to ingest..."
                    IsReadOnly="True"
                    VerticalAlignment="Center" />
                <Button
                    Grid.Column="1"
                    x:Name="BrowseButton"
                    Content="Browse..."
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Click="BrowseButton_Click"
                    IsEnabled="{x:Bind ViewModel.IsIngesting, Mode=OneWay, Converter={StaticResource InvertBoolConverter}}" />
            </Grid>

            <!-- Options row -->
            <StackPanel Orientation="Horizontal" Spacing="16">
                <ToggleSwitch
                    x:Name="FreshToggle"
                    Header="Fresh ingestion"
                    IsOn="{x:Bind ViewModel.FreshIngestion, Mode=TwoWay}"
                    IsEnabled="{x:Bind ViewModel.IsIngesting, Mode=OneWay, Converter={StaticResource InvertBoolConverter}}"
                    OffContent="Incremental (skip known files)"
                    OnContent="Full re-index (clear existing index)" />
            </StackPanel>

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button
                    Command="{x:Bind ViewModel.IngestCommand}"
                    Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE7C3;" FontSize="14" />
                        <TextBlock Text="Start Ingestion" />
                    </StackPanel>
                </Button>
                <Button
                    Command="{x:Bind ViewModel.CancelCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE711;" FontSize="14" />
                        <TextBlock Text="Cancel" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Separator -->
            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Progress section -->
        <StackPanel Grid.Row="1" Spacing="8" Margin="0,16,0,16">
            <ProgressBar
                Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                Maximum="100"
                IsIndeterminate="{x:Bind ViewModel.IsProgressIndeterminate, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsIngesting, Mode=OneWay}" />

            <Grid ColumnDefinitions="*,Auto" Visibility="{x:Bind ViewModel.IsIngesting, Mode=OneWay}">
                <TextBlock
                    Grid.Column="0"
                    Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Opacity="0.7"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Grid.Column="1"
                    Opacity="0.7"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Visibility="{x:Bind ViewModel.TotalFiles, Mode=OneWay, Converter={StaticResource NonZeroToVisibilityConverter}}">
                    <Run Text="{x:Bind ViewModel.FilesCompleted, Mode=OneWay}" />
                    <Run Text=" / " />
                    <Run Text="{x:Bind ViewModel.TotalFiles, Mode=OneWay}" />
                    <Run Text=" files" />
                </TextBlock>
            </Grid>

            <!-- Post-run status (shown when not ingesting but we have a result) -->
            <TextBlock
                Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Opacity="0.7"
                Visibility="{x:Bind ViewModel.IsIngesting, Mode=OneWay, Converter={StaticResource InvertBoolToVisibilityConverter}}" />
        </StackPanel>

        <!-- Log section -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*">
            <TextBlock
                Grid.Row="0"
                Text="Activity Log"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Margin="0,0,0,8" />

            <Border
                Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                Padding="12">
                <ListView
                    x:Name="LogList"
                    ItemsSource="{x:Bind ViewModel.Log}"
                    ItemTemplate="{StaticResource LogEntryTemplate}"
                    SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>

                    <!-- Empty state -->
                    <ListView.Footer>
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,40,0,0"
                            Visibility="{x:Bind ViewModel.Log.Count, Mode=OneWay, Converter={StaticResource ZeroToVisibilityConverter}}">
                            <FontIcon
                                Glyph="&#xE7C3;"
                                FontSize="36"
                                Opacity="0.2"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,12" />
                            <TextBlock
                                Text="No activity yet — select a folder and start ingestion"
                                Opacity="0.35"
                                HorizontalAlignment="Center" />
                        </StackPanel>
                    </ListView.Footer>
                </ListView>
            </Border>
        </Grid>
    </Grid>
</Page>
